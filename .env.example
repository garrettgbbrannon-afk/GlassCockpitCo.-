# Optional: enables Google sign-in + cross-device progress sync via Firebase.
# The app works fully without these — progress just stays on-device.
#
# To enable:
#   1. Go to https://console.firebase.google.com, create a project (free tier is enough).
#   2. Authentication -> Sign-in method -> enable Google.
#   3. Firestore Database -> Create database (production mode, any region).
#   4. Firestore Database -> Rules -> paste the contents of firestore.rules from this repo -> Publish.
#   5. Project settings -> General -> Your apps -> Add app -> Web -> copy the config values below.
#   6. Add these same values as environment variables in your Vercel project settings
#      (Settings -> Environment Variables), then redeploy.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
